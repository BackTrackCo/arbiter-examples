# Client — makes paid requests through the x402 flow

# Wallet (needs ETH for gas + USDC for payments)
PRIVATE_KEY=0x...

# Chain
CHAIN_ID=84532

# Merchant URL
MERCHANT_URL=http://localhost:4021

# Arbiter URL (for polling verdicts). Optional: if unset, the client pulls it
# from the merchant's 402 response (extensions.attestation.info.identity.url).
# ARBITER_URL=http://localhost:3001
