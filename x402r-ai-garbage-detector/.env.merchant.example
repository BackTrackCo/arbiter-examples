# Merchant — serves paid API endpoints with x402 payment middleware

# Wallet (needs ETH for gas on EIP-712 receipt signing mode)
# For JWS mode (merchant:jws), set MERCHANT_ADDRESS instead
PRIVATE_KEY=0x...
# MERCHANT_ADDRESS=0x...   # JWS mode only — no wallet needed

# Chain
CHAIN_ID=84532

# Facilitator URL (x402 payment settlement)
FACILITATOR_URL=http://localhost:4022

# Arbiter URL (garbage detection + attestation)
ARBITER_URL=http://localhost:3001

# Operator (from `pnpm run setup`)
OPERATOR_ADDRESS=0x...

MERCHANT_PORT=4021
