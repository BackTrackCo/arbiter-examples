# Arbiter — evaluates response bodies, releases escrowed funds on PASS
# Also used by `pnpm run setup` to deploy operator contracts

# Wallet (needs ETH for gas + USDC if using clawrouter)
PRIVATE_KEY=0x...

# Inference provider: "clawrouter" | "openai" | "ollama" | "eigenai"
INFERENCE_PROVIDER=clawrouter
INFERENCE_SEED=42

# ClawRouter (default — pays with USDC via x402, no API key)
# CLAWROUTER_MODEL=openai/gpt-4o-mini

# OpenAI-compatible (requires API key)
# INFERENCE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local model — best for EigenCloud TEE)
# INFERENCE_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b

# Chains — comma-separated, arbiter supports multiple chains
CHAIN_IDS=84532

# Per-chain RPC overrides (optional)
# RPC_84532=https://sepolia.base.org

# Operator (deployed via `pnpm run setup`, or set manually)
OPERATOR_ADDRESS=0x...
ESCROW_PERIOD_ADDRESS=0x...

ARBITER_PORT=3001
