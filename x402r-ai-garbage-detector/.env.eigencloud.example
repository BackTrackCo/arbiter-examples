# EigenCloud TEE Deployment Environment
# Copy to .env before deploying: cp .env.eigencloud.example .env
#
# PRIVATE_KEY gives persistent arbiter identity across deployments.
# TEE encrypts it at rest. Must have ETH for gas (release txs).

PRIVATE_KEY=0x...

# Inference: ollama for full TEE attestation, clawrouter for zero-config
# With ollama, model weights are baked into the Docker image (see Dockerfile).
INFERENCE_PROVIDER=ollama
INFERENCE_SEED=42

# Ollama runs inside the container — no external config needed
# OLLAMA_MODEL=llama3.1:8b           # must match Dockerfile OLLAMA_MODEL build arg
# OLLAMA_BASE_URL=http://localhost:11434

# --- Alternative: ClawRouter (pays with USDC, no model in container) ---
# INFERENCE_PROVIDER=clawrouter
# CLAWROUTER_MODEL=openai/gpt-4o-mini

# Chains — comma-separated chain IDs
CHAIN_IDS=84532

# Per-chain RPC overrides (optional)
# RPC_84532=https://sepolia.base.org

# Operator address (deployed via `pnpm run setup` before TEE deployment)
OPERATOR_ADDRESS=0x...
ESCROW_PERIOD_ADDRESS=0x...

# Arbiter port
ARBITER_PORT=3001
