# Wallet private key (with Base Sepolia ETH + USDC)
PRIVATE_KEY=0x...

# Inference provider: "openai" | "ollama" | "eigenai"
INFERENCE_PROVIDER=openai
INFERENCE_SEED=42

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (local model, best for TEE) ---
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# --- EigenAI (deterministic, currently unavailable) ---
# EIGENAI_GRANT_SERVER=https://determinal-api.eigenarcade.com
# EIGENAI_MODEL=gpt-oss-120b-f16

# Chain (default: Base Sepolia)
CHAIN_ID=84532

# Operator address (deployed via `pnpm run setup`)
OPERATOR_ADDRESS=0x...
