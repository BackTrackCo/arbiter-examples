# Wallet private key (with ETH for gas + USDC for clawrouter inference)
PRIVATE_KEY=0x...

# Inference provider: "clawrouter" | "openai" | "ollama" | "eigenai"
# Default: clawrouter (pays with arbiter's wallet, no API key needed)
INFERENCE_PROVIDER=clawrouter
INFERENCE_SEED=42

# --- ClawRouter (default — pays with USDC via x402, no API key needed) ---
# Uses the arbiter's existing wallet. 55+ models with smart routing.
# CLAWROUTER_MODEL=openai/gpt-4o-mini
# CLAWROUTER_BASE_URL=https://blockrun.ai/api/v1

# --- OpenAI-compatible (requires API key) ---
# Works with OpenAI, OpenRouter, Together, vLLM, LiteLLM, etc.
# INFERENCE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (access Claude, Llama, Mistral via one API):
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=anthropic/claude-sonnet-4

# --- Ollama (local model — best for EigenCloud TEE) ---
# INFERENCE_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# --- EigenAI (deterministic, currently unavailable) ---
# INFERENCE_PROVIDER=eigenai
# EIGENAI_GRANT_SERVER=https://determinal-api.eigenarcade.com
# EIGENAI_MODEL=gpt-oss-120b-f16

# Chains — comma-separated chain IDs (default: Base Sepolia)
CHAIN_IDS=84532

# Per-chain RPC overrides (optional — uses viem defaults if unset)
# RPC_84532=https://sepolia.base.org
# RPC_8453=https://mainnet.base.org

# Operator address (deployed via `pnpm run setup`)
OPERATOR_ADDRESS=0x...
ESCROW_PERIOD_ADDRESS=0x...

# Arbiter port
ARBITER_PORT=3001
