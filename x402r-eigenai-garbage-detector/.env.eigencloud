# EigenCloud TEE Deployment Environment
# PRIVATE_KEY gives persistent identity across deployments (TEE encrypts it)

# Arbiter wallet (must have ETH for gas + USDC if using clawrouter)
PRIVATE_KEY=0x...

# Inference provider: "ollama" for full TEE attestation, "clawrouter" for zero-config
INFERENCE_PROVIDER=ollama
INFERENCE_SEED=42

# Chain Configuration (Base Sepolia)
CHAIN_ID=84532

# Operator address (deployed via `pnpm run setup`)
OPERATOR_ADDRESS=0x...
