{
  "name": "x402r-kleros-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:contracts": "cd contracts && forge build",
    "generate:abi": "tsx src/scripts/generate-abi.ts",
    "build": "pnpm run build:contracts && pnpm run generate:abi",
    "setup": "tsx --env-file=.env.payer src/scripts/setup.ts",
    "client": "tsx --env-file=.env.payer src/scripts/client.ts",
    "merchant": "tsx --env-file=.env.merchant src/scripts/merchant.ts",
    "arbiter": "tsx --env-file=.env.arbiter src/scripts/arbiter.ts",
    "deploy-ruler": "tsx --env-file=.env.payer src/scripts/deploy-ruler.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kleros/kleros-v2-contracts": "^0.12.0",
    "@pinata/sdk": "^2.1.0",
    "@x402r/core": "0.1.0",
    "@x402r/sdk": "0.1.0",
    "viem": "2.47.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.0"
  }
}
